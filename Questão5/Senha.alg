algoritmo "Senha"
// Autor : Miguel Caparroz
// Data : 13/04/2026

var
//variavel
  senha :literal
inicio
// Seção de Comandos

   escreva("Informe a senha:")
   leia(senha)


//calculos
        se senha = "acb23" entao
   escreval("Senha correta")
   leia(senha)
   senao
   escreval("Senha incorreta")
   leia(senha)

fimalgoritmo

