algoritmo "Idade Para Dirigir"
// Autor : Miguel Caparroz
// Data : 13/04/2026

var
//variavel
  idade:real
inicio
// Seçăo de Comandos

   escreva("Informe sua idade:")
   leia(idade)


//calculos
        se idade <= 17 entao
   escreval("Vocę năo pode dirigir")
   leia(idade)
   senao
   escreval("Vocę pode dirigir")
   leia(idade)

fimalgoritmo

